# ============================================================
#  CleanIT — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the .env file to version control.
# ============================================================

# ── Supabase ──
# Found at: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_REF=your_project_ref_here

# ── QR Code Signing ──
# Generate with: openssl rand -hex 32
# Must match the value set in Supabase Edge Function Secrets
QR_SIGNING_SECRET=your_random_32_char_hex_string_here

# ── Firebase ──
# Firebase project ID (from Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID=your_firebase_project_id
